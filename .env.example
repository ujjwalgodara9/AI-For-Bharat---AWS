# ═══════════════════════════════════════════════════
# MandiMitra — Environment Variables
# Copy this to .env and fill in the values
# ═══════════════════════════════════════════════════

# ─── AWS Configuration ─────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── DynamoDB ──────────────────────────────────────
PRICE_TABLE=MandiMitraPrices

# ─── S3 ────────────────────────────────────────────
S3_BUCKET=mandimitra-data

# ─── data.gov.in API ──────────────────────────────
# Register at https://data.gov.in/user/register (free)
DATA_GOV_API_KEY=

# ─── Amazon Bedrock Agents ─────────────────────────
# Fill after creating agents in AWS Bedrock Console
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# ─── LangFuse (LLM Observability) ─────────────────
# Register at https://langfuse.com (free tier)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Frontend ──────────────────────────────────────
# Set this to your API Gateway URL after deployment
NEXT_PUBLIC_API_URL=
